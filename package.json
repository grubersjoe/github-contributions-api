{
  "name": "github-contribution-api",
  "description": "Scrape contribution data of a Github user",
  "version": "4.10.0",
  "author": "Jonathan Gruber <gruberjonathan@gmail.com>",
  "license": "MIT",
  "private": true,
  "main": "build/server.js",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "rm -rf build/* && tsc -p tsconfig.build.json",
    "check": "pnpm install --frozen-lockfile --ignore-scripts && prettier -c . && pnpm typecheck && pnpm lint && pnpm test",
    "dev": "nodemon src/server.ts --exec ts-node src/server.ts",
    "format": "prettier --write .",
    "lint": "eslint .",
    "postinstall": "npm run build",
    "prepare": "husky",
    "prestart": "npm run build",
    "start": "node build/server.js",
    "test": "jest",
    "typecheck": "tsc"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/grubersjoe/github-contributions-api.git"
  },
  "bugs": {
    "url": "git+https://github.com/grubersjoe/github-contributions-api.git"
  },
  "keywords": [
    "github",
    "contributions",
    "calendar",
    "node"
  ],
  "dependencies": {
    "cheerio": "^1.2.0",
    "compression": "^1.8.1",
    "console-stamp": "^3.1.2",
    "cors": "^2.8.6",
    "domhandler": "^5.0.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "memory-cache": "^0.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-typescript": "^7.28.5",
    "@eslint/js": "^10.0.1",
    "@tsconfig/bases": "^1.0.23",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/memory-cache": "^0.2.6",
    "@types/node": "^22.19.17",
    "@types/supertest": "^7.2.0",
    "eslint": "^10.2.0",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.2",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1"
  },
  "prettier": {
    "semi": false,
    "singleQuote": true
  }
}
